{
  "name": "wp-theme-base",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:codetot-ai/wp-theme-base.git"
  },
  "author": {
    "name": "CODE TOT",
    "email": "tech@codetot.com",
    "url": "https://codetot.com"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "NODE_ENV=production vite build",
    "critical": "node scripts/critical.mjs",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src/js/",
    "lint:css": "stylelint 'src/postcss/**/*.css'",
    "lint:fix": "eslint src/js/ --fix && stylelint 'src/postcss/**/*.css' --fix",
    "format": "prettier --write 'src/**/*.{js,css}'",
    "format:check": "prettier --check 'src/**/*.{js,css}'",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "validate": "npm run lint && npm run format:check && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.php": "vendor/bin/phpcs --standard=phpcs.xml --runtime-set ignore_warnings_on_exit 1",
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "autoprefixer": "^10.4.12",
    "critical": "^7.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^11.0.3",
    "postcss-preset-env": "^10.1.5",
    "prettier": "^3.8.3",
    "sass": "^1.86.0",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^6.2.5"
  },
  "dependencies": {
    "bootstrap": "^5.2.3",
    "swiper": "^11.2.6"
  }
}
